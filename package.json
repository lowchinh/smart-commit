{
  "name": "@lowchinh/smart-commit",
  "version": "1.0.0",
  "description": "Atomic git commits grouped by feature/layer — works with Claude Code, Copilot, Codex, Gemini",
  "bin": {
    "smart-commit": "./bin/cli.js"
  },
  "scripts": {
    "postinstall": "node ./bin/setup.js --silent"
  },
  "files": [
    "bin/",
    "lib/",
