  "keywords": ["git", "commit", "ai", "claude", "copilot", "codex", "gemini"],
  "author": "lowchinh",
  "license": "MIT",
  "homepage": "https://github.com/lowchinh/smart-commit",
  "repository": {
    "type": "git",
    "url": "https://github.com/lowchinh/smart-commit.git"
  },
  "engines": {
    "node": ">=16"
  }
